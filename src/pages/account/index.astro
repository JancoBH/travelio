---
import AppHeader from "../../components/AppHeader.astro";
import AccountWorkspaceClient from "../../components/AccountWorkspaceClient";
import Footer from "../../components/Footer.astro";
import Layout from "../../layouts/Layout.astro";
import { pastBookings, upcomingBookings, userHighlights } from "../../data/dashboard";
---

<Layout title="My Bookings | Travelio" description="A clean traveler dashboard with upcoming bookings, past trips, wishlist, and profile-focused account modules.">
  <AppHeader currentPath="/account" />

  <main id="main-content" class="pb-20 pt-10 sm:pb-24">
    <div class="container-shell">
        <section class="space-y-6">
          <div class="surface-dark p-7 sm:p-8">
            <p data-i18n="account.eyebrow" class="text-sm font-medium uppercase tracking-[0.24em] text-brand-accent">User Dashboard</p>
            <h1 data-i18n="account.title" class="mt-3 text-3xl font-semibold tracking-tight text-white">Welcome back, John</h1>
            <p data-i18n="account.copy" class="mt-3 text-sm leading-7 text-white/72">
              A concise traveler-facing account area with booking states, wishlist, and repeat-trip visibility.
            </p>

            <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
              {userHighlights.map((item) => (
                <div class="rounded-3xl border border-white/10 bg-white/8 p-5">
                  <div data-i18n={item.labelKey} class="text-sm text-white/60">{item.label}</div>
                  <div class="mt-2 text-3xl font-semibold tracking-tight text-white">{item.value}</div>
                </div>
              ))}
            </div>
          </div>

          <AccountWorkspaceClient client:load upcomingBookings={upcomingBookings} pastBookings={pastBookings} />
        </section>
    </div>
  </main>

  <Footer />
</Layout>
