---
import AppHeader from "../../components/AppHeader.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import Layout from "../../layouts/Layout.astro";
import WishlistActionButton from "../../components/WishlistActionButton";
import { tours } from "../../data/tours";

export function getStaticPaths() {
  return tours.map((tour) => ({
    params: { slug: tour.slug },
    props: { tour },
  }));
}

const { tour } = Astro.props;
const [heroImage, ...gallery] = tour.gallery;
---

<Layout title={`${tour.name} | Travelio`} description={tour.description}>
  <AppHeader currentPath="/tours" />

  <main id="main-content" class="pb-20 pt-10 sm:pb-24">
    <div class="container-shell">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <section>
          <div class="overflow-hidden rounded-[32px] bg-brand-dark">
            <div class="relative">
              <img src={heroImage} alt={tour.alt} class="h-[440px] w-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/75 to-transparent"></div>
              <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
                <p class="text-sm text-white/72">
                  <a href="/tours" data-i18n="nav.tours" class="hover:text-white">Tours</a>
                  <span class="mx-2">/</span>
                  <a href={`/destinations/${tour.destinationSlug}`} class="hover:text-white">{tour.destinationName}</a>
                </p>
                <h1 class="mt-4 max-w-2xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
                  {tour.name}
                </h1>
                <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-white/78">
                  <span class="flex items-center gap-2">
                    <Icon name="map-pin" class="h-4 w-4 text-brand-accent" />
                    {tour.location}
                  </span>
                  <span class="flex items-center gap-2">
                    <Icon name="star" class="h-4 w-4 text-brand-accent" />
                    {tour.rating} ({tour.reviews} <span data-i18n="tours.card.reviews">reviews</span>)
                  </span>
                  <span class="rounded-full border border-white/18 px-3 py-1">{tour.type}</span>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-4 gap-3 p-4 sm:p-5">
              {gallery.map((image, index) => (
                <img
                  src={image}
                  alt={`${tour.name} gallery image ${index + 2}`}
                  class="h-28 w-full rounded-2xl object-cover"
                />
              ))}
            </div>
          </div>

          <div class="mt-8 grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
            <div class="card-surface p-7 sm:p-8">
              <div class="flex flex-wrap items-center gap-3">
                <span class="rounded-full bg-brand-accent px-3 py-1 text-xs font-semibold text-brand-dark">{tour.badge}</span>
                <span class="rounded-full border border-brand-border px-3 py-1 text-xs font-semibold text-brand-muted">{tour.availability}</span>
              </div>
              <h2 data-i18n="tourDetail.overview" class="mt-5 text-2xl font-semibold tracking-tight text-brand-text">Tour Overview</h2>
              <p class="mt-4 text-sm leading-7 text-brand-muted">{tour.description}</p>

              <div class="mt-6 grid gap-4 sm:grid-cols-3">
                <div class="rounded-3xl bg-brand-bg p-4">
                  <div data-i18n="tourDetail.duration" class="text-sm text-brand-muted">Duration</div>
                  <div class="mt-2 font-semibold text-brand-text">{tour.durationDays} <span data-i18n="tours.card.days">Days</span></div>
                </div>
                <div class="rounded-3xl bg-brand-bg p-4">
                  <div data-i18n="tourDetail.groupSize" class="text-sm text-brand-muted">Group Size</div>
                  <div class="mt-2 font-semibold text-brand-text">{tour.groupSize}</div>
                </div>
                <div class="rounded-3xl bg-brand-bg p-4">
                  <div data-i18n="tourDetail.meetingPoint" class="text-sm text-brand-muted">Meeting Point</div>
                  <div class="mt-2 font-semibold text-brand-text">{tour.meetingPoint}</div>
                </div>
              </div>
            </div>

            <div class="card-surface p-7 sm:p-8">
              <h2 data-i18n="tourDetail.highlights" class="text-2xl font-semibold tracking-tight text-brand-text">Trip Highlights</h2>
              <ul class="mt-5 space-y-3 text-sm leading-7 text-brand-muted">
                {tour.includes.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 rounded-full bg-brand-accent"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

              <h3 data-i18n="tourDetail.excludes" class="mt-8 text-lg font-semibold tracking-tight text-brand-text">What's not included</h3>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-brand-muted">
                {tour.excludes.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 rounded-full bg-slate-300"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="mt-6 card-surface p-7 sm:p-8">
            <h2 data-i18n="tourDetail.itinerary" class="text-2xl font-semibold tracking-tight text-brand-text">Itinerary</h2>
            <div class="mt-6 space-y-5">
              {tour.itinerary.map((stop) => (
                <div class="rounded-3xl border border-brand-border bg-white p-5">
                  <div class="text-sm font-semibold text-brand-teal">{stop.day}</div>
                  <h3 class="mt-2 text-lg font-semibold tracking-tight text-brand-text">{stop.title}</h3>
                  <p class="mt-2 text-sm leading-7 text-brand-muted">{stop.description}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="mt-6 grid gap-6 xl:grid-cols-2">
            <div class="card-surface p-7 sm:p-8">
              <h2 data-i18n="tourDetail.cancellation" class="text-2xl font-semibold tracking-tight text-brand-text">Cancellation Policy</h2>
              <p class="mt-4 text-sm leading-7 text-brand-muted">{tour.cancellation}</p>
            </div>
            <div class="card-surface p-7 sm:p-8">
              <h2 data-i18n="tourDetail.reviews" class="text-2xl font-semibold tracking-tight text-brand-text">Traveler Reviews</h2>
              <div class="mt-5 space-y-4">
                {tour.reviewList.map((review) => (
                  <div class="rounded-3xl bg-brand-bg p-5">
                    <div class="flex items-center justify-between gap-4">
                      <div>
                        <div class="font-semibold text-brand-text">{review.author}</div>
                        <div class="text-sm text-brand-muted">{review.country}</div>
                      </div>
                      <div class="flex items-center gap-2 text-sm font-semibold text-brand-text">
                        <Icon name="star" class="h-4 w-4 text-brand-accent" />
                        {review.rating}
                      </div>
                    </div>
                    <p class="mt-3 text-sm leading-7 text-brand-muted">{review.comment}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>

        <aside class="h-fit lg:sticky lg:top-28">
          <div class="card-surface p-7 sm:p-8">
            <p data-i18n="tourDetail.from" class="text-sm text-brand-muted">From</p>
            <div class="mt-2 text-4xl font-semibold tracking-tight text-brand-text">${tour.price}</div>
            <p data-i18n="tourDetail.perPerson" class="mt-2 text-sm text-brand-muted">per person</p>

            <div class="mt-6 space-y-4">
              <div class="rounded-3xl border border-brand-border p-4">
                <div data-i18n="tourDetail.date" class="text-sm font-semibold text-brand-text">Date</div>
                <div class="mt-1 text-sm text-brand-muted">May 20 - May 24, 2026</div>
              </div>
              <div class="rounded-3xl border border-brand-border p-4">
                <div data-i18n="tourDetail.travelers" class="text-sm font-semibold text-brand-text">Travelers</div>
                <div class="mt-1 text-sm text-brand-muted">2 Adults</div>
              </div>
            </div>

            <div class="mt-6 rounded-3xl bg-brand-bg p-5">
              <div class="flex items-center justify-between text-sm text-brand-muted">
                <span data-i18n="tourDetail.tourPrice">Tour Price</span>
                <span>${tour.price * 2}</span>
              </div>
              <div class="mt-3 flex items-center justify-between text-sm text-brand-muted">
                <span data-i18n="tourDetail.serviceFee">Service Fee</span>
                <span>$144</span>
              </div>
              <div class="mt-4 border-t border-brand-border pt-4">
                <div class="flex items-center justify-between font-semibold text-brand-text">
                  <span data-i18n="tourDetail.total">Total</span>
                  <span>${tour.price * 2 + 144}</span>
                </div>
              </div>
            </div>

            <a href={`/booking?tour=${tour.slug}`} data-i18n="tourDetail.book" class="btn-primary mt-6 w-full">Book Now</a>
            <WishlistActionButton
              client:load
              item={{
                id: `tour:${tour.slug}`,
                kind: "tour",
                slug: tour.slug,
                name: tour.name,
                href: `/tours/${tour.slug}`,
                image: tour.image,
                location: tour.location,
                priceLabel: `$${tour.price}`,
              }}
            />
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
