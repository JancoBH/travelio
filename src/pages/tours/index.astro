---
import AppHeader from "../../components/AppHeader.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import ToursExplorerClient from "../../components/ToursExplorerClient";
import Layout from "../../layouts/Layout.astro";
import { tours } from "../../data/tours";
---

<Layout
  title="Find Your Perfect Tour | Travelio"
  description="Browse travel experiences, compare pricing, and explore curated tours with filters designed like a modern booking platform."
>
  <AppHeader currentPath="/tours" />
  <PageHero
    eyebrow="Tours Listing"
    eyebrowKey="tours.hero.eyebrow"
    title="Find your perfect tour"
    titleKey="tours.hero.title"
    description="A functional search results experience with filters, sorting, and a dense but polished card system designed to feel like a real booking interface."
    descriptionKey="tours.hero.copy"
    image="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1600&q=80"
  />

  <main id="main-content" class="pb-20 pt-16 sm:pb-24">
    <ToursExplorerClient client:load tours={tours} />
  </main>

  <Footer />
</Layout>
