---
import AppHeader from "../components/AppHeader.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Travelio" description="A support and contact page with a polished inquiry form, FAQ snippets, and clear traveler assistance channels.">
  <AppHeader currentPath="/contact" />
  <PageHero
    eyebrow="Contact"
    eyebrowKey="contact.hero.eyebrow"
    title="Support that feels reachable before and after booking"
    titleKey="contact.hero.title"
    description="This page rounds out the product story with visible contact channels, a clear form, and a practical FAQ block instead of decorative filler."
    descriptionKey="contact.hero.copy"
    image="https://images.unsplash.com/photo-1527631746610-bca00a040d60?auto=format&fit=crop&w=1600&q=80"
  />

  <main id="main-content" class="pb-20 pt-16 sm:pb-24">
    <div class="container-shell grid gap-6 xl:grid-cols-[1fr_0.9fr]">
      <section class="card-surface p-7 sm:p-8">
        <p data-i18n="contact.form.eyebrow" class="eyebrow">Get in Touch</p>
        <h1 data-i18n="contact.form.title" class="mt-3 text-3xl font-semibold tracking-tight text-brand-text">Tell us what you need help with</h1>
        <form class="mt-6 grid gap-4 sm:grid-cols-2">
          <input type="text" data-i18n-placeholder="booking.field.fullName" placeholder="Full Name" class="field-box field-control" />
          <input type="email" data-i18n-placeholder="booking.field.email" placeholder="Email" class="field-box field-control" />
          <input type="tel" data-i18n-placeholder="booking.field.phone" placeholder="Phone" class="field-box field-control sm:col-span-2" />
          <textarea data-i18n-placeholder="contact.form.message" placeholder="How can we help?" class="field-box field-control h-auto min-h-36 py-3 sm:col-span-2"></textarea>
          <button type="submit" data-i18n="contact.form.submit" class="btn-primary sm:col-span-2 sm:w-fit sm:justify-self-end">Send Message</button>
        </form>
      </section>

      <div class="space-y-6">
        <section class="card-surface p-7 sm:p-8">
          <p data-i18n="contact.channels" class="eyebrow">Support Channels</p>
          <div class="mt-5 space-y-4 text-sm leading-7 text-brand-muted">
            <p><span class="font-semibold text-brand-text">Email:</span> hello@travelio-demo.com</p>
            <p><span class="font-semibold text-brand-text">Phone:</span> +1 (234) 567 890</p>
            <p><span class="font-semibold text-brand-text">WhatsApp:</span> Available for trip support and itinerary questions.</p>
          </div>
        </section>

        <section class="card-surface p-7 sm:p-8">
          <p data-i18n="destinationDetail.faq" class="eyebrow">FAQ</p>
          <div class="mt-5 space-y-4">
            <div class="rounded-3xl bg-brand-bg p-5">
              <h2 class="font-semibold text-brand-text">Can I change my booking after confirmation?</h2>
              <p class="mt-3 text-sm leading-7 text-brand-muted">Yes, depending on the destination and cancellation policy shown in the tour detail page.</p>
            </div>
            <div class="rounded-3xl bg-brand-bg p-5">
              <h2 class="font-semibold text-brand-text">Do you offer custom trips?</h2>
              <p class="mt-3 text-sm leading-7 text-brand-muted">For demo purposes this remains a fixed inventory platform, but the interface is ready to support inquiry-led packages.</p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
