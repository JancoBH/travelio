---
import AppHeader from "../components/AppHeader.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Travelio" description="A portfolio-ready about page with product story, operational metrics, team values, and trust-building content for a travel platform.">
  <AppHeader currentPath="/about" />
  <PageHero
    eyebrow="About Travelio"
    eyebrowKey="about.hero.eyebrow"
    title="A travel platform concept designed like a real product"
    titleKey="about.hero.title"
    description="This is not positioned like a simple landing page mock. The idea is to show a commercially credible booking interface that could be adapted for client work, reuse, or portfolio presentation."
    descriptionKey="about.hero.copy"
    image="https://images.unsplash.com/photo-1517760444937-f6397edcbbcd?auto=format&fit=crop&w=1600&q=80"
  />

  <main id="main-content" class="pb-20 pt-16 sm:pb-24">
    <div class="container-shell space-y-6">
      <section class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
        <div class="card-surface p-7 sm:p-8">
          <p data-i18n="about.story.eyebrow" class="eyebrow">Our Story</p>
          <h1 data-i18n="about.story.title" class="mt-3 text-3xl font-semibold tracking-tight text-brand-text">Travel planning should feel premium before the trip even begins</h1>
          <p data-i18n="about.story.copy" class="mt-5 text-sm leading-7 text-brand-muted">
            Travelio is framed as a modern brand for curated experiences, combining clear discovery, high-quality destination storytelling, and cleaner booking flows than the usual cluttered travel marketplace.
          </p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="card-surface p-7">
            <div class="text-4xl font-semibold tracking-tight text-brand-text">10k+</div>
            <p data-i18n="about.stat.travelersCopy" class="mt-3 text-sm leading-7 text-brand-muted">Travelers served across premium package concepts.</p>
          </div>
          <div class="card-surface p-7">
            <div class="text-4xl font-semibold tracking-tight text-brand-text">250+</div>
            <p data-i18n="about.stat.toursCopy" class="mt-3 text-sm leading-7 text-brand-muted">Tours ready to expand into a larger product catalog.</p>
          </div>
          <div class="card-surface p-7">
            <div class="text-4xl font-semibold tracking-tight text-brand-text">40+</div>
            <p data-i18n="about.stat.destinationsCopy" class="mt-3 text-sm leading-7 text-brand-muted">Destinations supported by visual-first storytelling.</p>
          </div>
          <div class="card-surface p-7">
            <div class="text-4xl font-semibold tracking-tight text-brand-text">98%</div>
            <p data-i18n="about.stat.satisfactionCopy" class="mt-3 text-sm leading-7 text-brand-muted">Satisfaction indicator used as social proof in the brand layer.</p>
          </div>
        </div>
      </section>

      <section class="card-surface p-7 sm:p-8">
        <p data-i18n="about.values.eyebrow" class="eyebrow">Values</p>
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl bg-brand-bg p-6">
            <h2 data-i18n="about.value1.title" class="text-xl font-semibold tracking-tight text-brand-text">Curated quality</h2>
            <p data-i18n="about.value1.copy" class="mt-3 text-sm leading-7 text-brand-muted">Less clutter, better presentation, and intentional tour curation.</p>
          </div>
          <div class="rounded-3xl bg-brand-bg p-6">
            <h2 data-i18n="about.value2.title" class="text-xl font-semibold tracking-tight text-brand-text">Traveler clarity</h2>
            <p data-i18n="about.value2.copy" class="mt-3 text-sm leading-7 text-brand-muted">Pricing, timing, and policies are visible before commitment.</p>
          </div>
          <div class="rounded-3xl bg-brand-bg p-6">
            <h2 data-i18n="about.value3.title" class="text-xl font-semibold tracking-tight text-brand-text">Scalable product thinking</h2>
            <p data-i18n="about.value3.copy" class="mt-3 text-sm leading-7 text-brand-muted">The structure supports storefront, booking ops, and admin use cases.</p>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>
