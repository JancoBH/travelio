---
import { resolveUrl } from "../../lib/url";
import AppHeader from "../../components/AppHeader.astro";
import AdminWorkspaceClient from "../../components/AdminWorkspaceClient";
import Footer from "../../components/Footer.astro";
import Layout from "../../layouts/Layout.astro";
import { dashboardStats, recentBookings } from "../../data/dashboard";
---

<Layout title="Admin Dashboard | Travelio" description="A booking operations dashboard showing commercial metrics, booking status, recent reservations, and inventory management.">
  <AppHeader currentPath="/admin" />

  <main id="main-content" class="pb-20 pt-10 sm:pb-24">
    <div class="container-shell">
        <section class="space-y-6">
          <div class="card-surface p-7 sm:p-8">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
              <div>
                <p data-i18n="admin.eyebrow" class="eyebrow">Admin Dashboard</p>
                <h1 data-i18n="admin.title" class="mt-3 text-3xl font-semibold tracking-tight text-brand-text">Overview and booking management</h1>
              </div>
              <div class="flex flex-wrap gap-3">
                <a href={resolveUrl("/admin/components")} data-i18n="admin.components" class="btn-secondary">Component System</a>
                <a href="#inventory" data-i18n="admin.addTour" class="btn-secondary">Add Tour</a>
                <a href="#bookings" data-i18n="admin.viewBookings" class="btn-primary">View All Bookings</a>
              </div>
            </div>

            <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
              {dashboardStats.map((stat) => (
                <div class="rounded-3xl bg-brand-bg p-5">
                  <div data-i18n={stat.labelKey} class="text-sm text-brand-muted">{stat.label}</div>
                  <div class="mt-2 text-3xl font-semibold tracking-tight text-brand-text">{stat.value}</div>
                  <div class="mt-2 text-sm font-semibold text-emerald-600">{stat.delta}</div>
                </div>
              ))}
            </div>
          </div>

          <AdminWorkspaceClient client:load recentBookings={recentBookings} />
        </section>
    </div>
  </main>

  <Footer />
</Layout>
