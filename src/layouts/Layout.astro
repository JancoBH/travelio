---
import "../styles/global.css";
import { defaultLocale, messages } from "../i18n/messages";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Travelio | Modern Tour Booking Platform",
  description = "Discover premium tours, curated destinations, and seamless travel experiences with Travelio's modern booking platform.",
} = Astro.props;

const serializedMessages = JSON.stringify(messages);
---

<!doctype html>
<html lang={defaultLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-brand-bg text-brand-text antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-brand-text"
    >
      Skip to content
    </a>
    <slot />
    <script is:inline define:vars={{ serializedMessages, defaultLocale }}>
      const storageKey = "travelio-language";
      const eventName = "travelio:language-change";
      const dictionaries = JSON.parse(serializedMessages);

      const normalizeLocale = (value) => {
        if (typeof value !== "string") return defaultLocale;
        return value.toLowerCase().startsWith("es") ? "es" : defaultLocale;
      };

      const getLocale = () => {
        const stored = window.localStorage.getItem(storageKey);
        if (stored) return normalizeLocale(stored);
        return normalizeLocale(window.navigator.language);
      };

      const applyTranslations = (locale) => {
        const dictionary = dictionaries[locale] ?? dictionaries[defaultLocale];
        document.documentElement.lang = locale;

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          if (!key || !dictionary[key]) return;
          node.textContent = dictionary[key];
        });

        document.querySelectorAll("[data-i18n-placeholder]").forEach((node) => {
          const key = node.getAttribute("data-i18n-placeholder");
          if (!key || !dictionary[key]) return;
          node.setAttribute("placeholder", dictionary[key]);
        });
      };

      const initialLocale = getLocale();
      applyTranslations(initialLocale);

      window.addEventListener(eventName, (event) => {
        const locale = normalizeLocale(event.detail);
        window.localStorage.setItem(storageKey, locale);
        applyTranslations(locale);
      });
    </script>
  </body>
</html>
