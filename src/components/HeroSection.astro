---
import { resolveUrl } from "../lib/url";
import BenefitBar from "./BenefitBar.astro";
import AppHeader from "./AppHeader.astro";
import SearchBox from "./SearchBox.astro";
---

<section id="home" class="relative overflow-hidden bg-brand-dark">
  <AppHeader currentPath="/" transparent />

  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1800&q=80"
      alt="Panoramic alpine lake surrounded by mountains"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark via-brand-dark/72 to-brand-dark/30"></div>
    <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-brand-dark to-transparent"></div>
  </div>

  <div class="container-shell relative z-10 flex min-h-[980px] flex-col justify-end pb-12 pt-28 sm:min-h-[1040px] sm:pb-16 sm:pt-32 lg:min-h-[980px] lg:pb-20 lg:pt-36">
    <div class="max-w-3xl">
      <h1 data-i18n="hero.title" class="mt-6 max-w-2xl text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Explore the world with unforgettable tours and experiences
      </h1>
      <p data-i18n="hero.copy" class="mt-5 max-w-xl text-base leading-7 text-white/78 sm:text-lg">
        Discover handpicked adventures, flexible bookings, and destination experts that
        help every trip feel effortless from the first search to the final memory.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={resolveUrl("/tours")} data-i18n="hero.cta.explore" class="btn-primary">Explore Tours</a>
        <a href={resolveUrl("/destinations")} data-i18n="hero.cta.browse" class="btn-ghost-light">
          Browse Destinations
        </a>
      </div>
    </div>

    <div class="mt-10">
      <SearchBox />
    </div>

    <div class="relative z-0 mt-8">
      <BenefitBar />
    </div>
  </div>
</section>
