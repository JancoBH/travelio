---
import Icon from "./Icon.astro";
import SelectField from "./SelectField.astro";

const filters = {
  destination: ["All Destinations", "Bali", "Santorini", "Swiss Alps", "Machu Picchu"],
  duration: ["Any Duration", "1-3 Days", "4-7 Days", "8+ Days"],
  rating: ["Any Rating", "4.5+", "4.7+", "4.8+"],
  type: ["All Types", "Adventure", "Cultural", "Nature", "Luxury"],
  availability: ["Available", "Limited", "Sold Out"],
};
---

<div class="card-surface h-fit p-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-brand-bg text-brand-teal">
        <Icon name="filter" class="h-5 w-5" />
      </span>
      <h2 class="text-lg font-semibold tracking-tight text-brand-text">Filters</h2>
    </div>
    <button type="button" class="text-sm font-semibold text-brand-teal">Clear All</button>
  </div>

  <div class="mt-6 space-y-6">
    <div>
      <label for="tour-search" class="text-sm font-semibold text-brand-text">Search</label>
      <input
        id="tour-search"
        type="text"
        placeholder="Search destinations or tours..."
        class="mt-3 h-12 w-full rounded-2xl border border-brand-border bg-white px-4 text-sm text-brand-text outline-none focus:border-brand-teal"
      />
    </div>

    {Object.entries(filters).map(([key, values]) => (
      <SelectField
        id={`filter-${key}`}
        label={key.charAt(0).toUpperCase() + key.slice(1)}
        name={key}
        options={values}
        value={values[0]}
      />
    ))}

    <div>
      <div class="flex items-center justify-between text-sm font-semibold text-brand-text">
        <span>Price Range</span>
        <span class="text-brand-muted">$499 - $1,299</span>
      </div>
      <div class="mt-4 h-2 rounded-full bg-slate-200">
        <div class="h-2 w-2/3 rounded-full bg-brand-accent"></div>
      </div>
    </div>
  </div>
</div>
