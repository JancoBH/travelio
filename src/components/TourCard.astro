---
import { resolveUrl } from "../lib/url";
import FavoriteButton from "./FavoriteButton";
import Icon from "./Icon.astro";
import type { Tour } from "../data/tours";

interface Props {
  tour: Tour;
}

const { tour } = Astro.props;
---

<article class="card-surface group overflow-hidden transition duration-300 hover:-translate-y-1 hover:shadow-[0_26px_56px_rgba(6,20,35,0.14)]">
  <div class="relative">
    <a href={resolveUrl(`/tours/${tour.slug}`)} class="block">
      <img
        src={tour.image}
        alt={tour.alt}
        class="h-64 w-full object-cover transition duration-500 group-hover:scale-[1.03]"
      />
    </a>
    <div class="absolute inset-x-0 top-0 flex items-center justify-between p-4">
      <span class="rounded-full bg-brand-accent px-3 py-1 text-xs font-semibold text-brand-dark">
        {tour.badge}
      </span>
      <FavoriteButton
        client:idle
        ariaLabel={`Save ${tour.name} to favorites`}
        light
        item={{
          id: `tour:${tour.slug}`,
          kind: "tour",
          slug: tour.slug,
          name: tour.name,
          href: resolveUrl(`/tours/${tour.slug}`),
          image: tour.image,
          location: tour.location,
          priceLabel: `$${tour.price}`,
        }}
      />
    </div>
  </div>

  <div class="p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <a href={resolveUrl(`/tours/${tour.slug}`)} class="text-xl font-semibold tracking-tight text-brand-text transition hover:text-brand-teal">
          {tour.name}
        </a>
        <p class="mt-2 flex items-center gap-2 text-sm text-brand-muted">
          <Icon name="map-pin" class="h-4 w-4 text-brand-teal" />
          {tour.location}
        </p>
      </div>
    </div>

    <div class="mt-5 flex items-center gap-2 text-sm">
      <span class="flex items-center gap-1 font-semibold text-brand-text">
        <Icon name="star" class="h-4 w-4 text-brand-accent" />
        {tour.rating}
      </span>
      <span class="text-brand-muted">({tour.reviews} reviews)</span>
    </div>

    <div class="mt-5 flex items-center justify-between gap-4 border-t border-brand-border pt-5">
      <p class="text-sm text-brand-muted">
        From <span class="text-2xl font-semibold tracking-tight text-brand-text">${tour.price}</span>
      </p>
      <p class="flex items-center gap-2 text-sm text-brand-muted">
        <Icon name="clock" class="h-4 w-4 text-brand-teal" />
        {tour.durationDays} Days
      </p>
    </div>

    <div class="mt-5 flex gap-3">
      <a href={resolveUrl(`/tours/${tour.slug}`)} class="btn-secondary min-w-0 flex-1 px-4">Details</a>
      <a href={resolveUrl(`/booking?tour=${tour.slug}`)} class="btn-primary min-w-0 flex-1 px-4">Book Now</a>
    </div>
  </div>
</article>
