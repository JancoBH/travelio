---
import Icon from "./Icon.astro";

interface Props {
  id?: string;
  label?: string;
  name?: string;
  options: string[];
  value?: string;
  class?: string;
}

const { id, label, name, options, value, class: className = "" } = Astro.props;
---

<div class={className}>
  {label && <label for={id} class="block text-sm font-semibold text-brand-text">{label}</label>}
  <div class:list={["select-shell", label && "mt-3"]}>
    <select id={id} name={name} class="select-input">
      {options.map((option) => (
        <option selected={value === option}>{option}</option>
      ))}
    </select>
    <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-brand-muted">
      <Icon name="chevron-down" class="h-4 w-4" />
    </span>
  </div>
</div>
