---
interface Props {
  name:
    | "search"
    | "calendar"
    | "users"
    | "map-pin"
    | "shield"
    | "star"
    | "headset"
    | "badge"
    | "heart"
    | "clock"
    | "globe"
    | "plane"
    | "chevron-down"
    | "chevron-right"
    | "filter"
    | "check-circle"
    | "sparkles";
  class?: string;
}

const { name, class: className = "h-5 w-5" } = Astro.props;
---

{
  name === "search" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
  )
}
{
  name === "calendar" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M16 3v4M8 3v4M3 11h18"></path></svg>
  )
}
{
  name === "users" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path><circle cx="9.5" cy="7" r="3.5"></circle><path d="M20 8.5a3 3 0 0 1 0 5.8M21 21v-2a4 4 0 0 0-3-3.87"></path></svg>
