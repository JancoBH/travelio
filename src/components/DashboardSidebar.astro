---
import type { TranslationKey } from "../i18n/messages";
import Icon from "./Icon.astro";

interface Item {
  label: string;
  href: string;
  labelKey?: TranslationKey;
}

interface Props {
  title: string;
  items: Item[];
  currentPath?: string;
  dark?: boolean;
}

const { title, items, currentPath = "", dark = false } = Astro.props;
---

<aside
  class:list={[
    "rounded-[28px] p-4 sm:p-5",
    dark
      ? "bg-brand-dark text-white shadow-[0_20px_60px_rgba(6,20,35,0.16)]"
      : "border border-brand-border bg-white text-brand-text shadow-card",
  ]}
>
  <div class="mb-6 flex items-center gap-3">
    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-accent text-brand-dark">
      <Icon name="map-pin" class="h-5 w-5" />
    </span>
    <div>
      <div class="font-semibold tracking-tight">{title}</div>
      <div data-i18n="sidebar.workspace" class:list={["text-xs", dark ? "text-white/58" : "text-brand-muted"]}>Travelio workspace</div>
    </div>
  </div>

  <nav class="space-y-1.5">
    {items.map((item) => {
      const active = currentPath === item.href;
      return (
        <a
          href={item.href}
          class:list={[
            "block rounded-2xl px-4 py-3 text-sm transition",
            dark
              ? active
                ? "bg-white/12 text-white"
                : "text-white/72 hover:bg-white/8 hover:text-white"
              : active
                ? "bg-brand-dark text-white"
                : "text-brand-muted hover:bg-slate-50 hover:text-brand-text",
          ]}
        >
          <span data-i18n={item.labelKey}>{item.label}</span>
        </a>
      );
    })}
  </nav>
</aside>
